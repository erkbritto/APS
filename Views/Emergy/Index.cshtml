@model List<APS.Models.Calculo>
@{
    ViewData["Title"] = "Cálculo Emergético";
    Layout = "_Layout";
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">
    <style>
            :root {
                --primary-dark: #2C3E50;
                --primary-green: #1ABC9C;
                --primary-green-hover: #16a085;
                --danger: #E74C3C;
                --danger-hover: #C0392B;
                --secondary: #95A5A6;
                --secondary-hover: #7f8c8d;
                --background: #F8F9FA;
            }

            body {
                background-color: var(--background);
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                color: #333;
            }

            .header {
                text-align: center;
                padding: 50px 0;
                background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary-green) 100%);
                color: white;
                border-radius: 0 0 20px 20px;
                margin-bottom: 30px;
                box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
            }

                .header h1 {
                    font-size: 3rem;
                    font-weight: bold;
                    margin-bottom: 10px;
                    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
                }

                .header p {
                    font-size: 1.2rem;
                    opacity: 0.95;
                }

            .container {
                max-width: 1000px;
                margin: 0 auto;
            }

            .card {
                border: none;
                border-radius: 15px;
                box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
                margin-bottom: 20px;
                transition: transform 0.3s ease, box-shadow 0.3s ease;
            }

                .card:hover {
                    transform: translateY(-5px);
                    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
                }

            .card-header {
                background-color: var(--primary-dark);
                color: white;
                font-weight: bold;
                border-radius: 15px 15px 0 0;
                padding: 15px;
                border: none;
            }

            .card-body {
                padding: 25px;
            }

            .btn-primary {
                background-color: var(--primary-green);
                border: none;
                border-radius: 10px;
                padding: 12px 25px;
                transition: all 0.3s ease;
                font-weight: 500;
            }

                .btn-primary:hover {
                    background-color: var(--primary-green-hover);
                    box-shadow: 0 4px 12px rgba(26, 188, 156, 0.3);
                }

            .btn-danger {
                background-color: var(--danger);
                border: none;
                border-radius: 10px;
                padding: 6px 12px;
                font-size: 0.85rem;
                transition: all 0.3s ease;
            }

                .btn-danger:hover {
                    background-color: var(--danger-hover);
                }

            .btn-secondary {
                background-color: var(--secondary);
                border: none;
                border-radius: 10px;
                padding: 12px 25px;
                transition: all 0.3s ease;
            }

                .btn-secondary:hover {
                    background-color: var(--secondary-hover);
                }

            .form-control {
                border-radius: 10px;
                border: 2px solid #ced4da;
                padding: 12px;
                transition: border-color 0.3s ease;
            }

                .form-control:focus {
                    border-color: var(--primary-green);
                    box-shadow: 0 0 0 0.2rem rgba(26, 188, 156, 0.25);
                }

            .form-label {
                font-weight: 500;
                color: var(--primary-dark);
                margin-bottom: 8px;
            }

            .alert {
                border-radius: 10px;
                border: none;
                padding: 15px;
                margin-bottom: 20px;
            }

            .alert-success {
                background-color: #D4EDDA;
                color: #155724;
            }

            .alert-danger {
                background-color: #F8D7DA;
                color: #721C24;
            }

            .alert-info {
                background-color: #D1ECF1;
                color: #0C5460;
            }

            .history-table {
                margin-top: 30px;
            }

            .table {
                border-radius: 10px;
                overflow: hidden;
            }

                .table thead th {
                    background-color: var(--primary-dark);
                    color: white;
                    border: none;
                    padding: 15px;
                    font-weight: 600;
                }

                .table tbody tr {
                    transition: background-color 0.3s ease;
                }

                    .table tbody tr:hover {
                        background-color: var(--background);
                    }

                .table tbody td {
                    vertical-align: middle;
                    padding: 12px 15px;
                }

            .empty-state {
                text-align: center;
                padding: 30px;
                color: var(--secondary);
            }

            .about-section {
                margin-top: 40px;
                padding: 30px;
                background-color: white;
                border-radius: 15px;
                box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
                margin-bottom: 40px;
            }

                .about-section h2 {
                    color: var(--primary-dark);
                    font-size: 2rem;
                    margin-bottom: 20px;
                    font-weight: bold;
                }

                .about-section strong {
                    color: var(--primary-green);
                }

            .status-badge {
                display: inline-block;
                padding: 4px 12px;
                border-radius: 20px;
                font-size: 0.85rem;
                font-weight: 500;
            }

                .status-badge.estático {
                    background-color: #E8F4F8;
                    color: var(--primary-green);
                }

                .status-badge.dinâmico {
                    background-color: #F4E8F8;
                    color: #9B59B6;
                }

            .input-group-text {
                border-radius: 0 10px 10px 0;
                background-color: var(--primary-dark);
                color: white;
                border: none;
            }

            @@media (max-width: 768px) {
                .header h1 {
                    font-size: 2rem;
                }
            
                .header p {
                    font-size: 1rem;
                }
            
                .table {
                    font-size: 0.9rem;
                }
            
                .btn {
                    width: 100%;
                    margin-bottom: 5px;
                }
            }
    </style>
</head>
<body>
    <header class="header">
        <h1><i class="fas fa-bolt"></i> Cálculo Emergético</h1>
        <p>Sistema de Análise de Emergia para Sustentabilidade</p>
    </header>

    <div class="container pb-5">
        @if (ViewBag.Mensagem != null)
        {
            <div class="alert @(ViewBag.TipoMensagem ?? "alert-info") alert-dismissible fade show" role="alert">
                <i class="fas @(ViewBag.TipoMensagem == "alert-danger" ? "fa-exclamation-circle" : "fa-check-circle") me-2"></i>
                <strong>@ViewBag.Mensagem</strong>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (ViewBag.Erro != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-times-circle me-2"></i>
                <strong>Erro:</strong> @ViewBag.Erro
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="row g-4">
            <div class="col-lg-6">
                <div class="card h-100">
                    <div class="card-header">
                        <i class="fas fa-calculator me-2"></i> Cálculo de Emergia Estática
                    </div>
                    <div class="card-body">
                        <form asp-action="CalcularEstatico" method="post">
                            @Html.AntiForgeryToken()
                            <div class="mb-3">
                                <label for="mj" class="form-label">
                                    <i class="fas fa-bolt me-2 text-primary"></i>Valor em MJ (Megajoules):
                                </label>
                                <div class="input-group">
                                    <input type="number" step="0.01" name="mj" id="mj" class="form-control" required min="0" placeholder="0.00" />
                                    <span class="input-group-text">MJ</span>
                                </div>
                                <small class="text-muted d-block mt-2">
                                    <i class="fas fa-info-circle me-1"></i>
                                    Fator de conversão: 1 MJ = 1.96E+04 Msej
                                </small>
                            </div>
                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-calculator me-2"></i> Calcular Estático
                                </button>
                                <button type="button" class="btn btn-secondary" onclick="document.getElementById('mj').value=''; document.getElementById('mj').focus();">
                                    <i class="fas fa-redo me-2"></i> Limpar
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="card h-100">
                    <div class="card-header">
                        <i class="fas fa-box me-2"></i> Cálculo de Emergia Dinâmica
                    </div>
                    <div class="card-body">
                        <form asp-action="CalcularDinamico" method="post">
                            @Html.AntiForgeryToken()
                            <div class="mb-3">
                                <label for="estoque" class="form-label">
                                    <i class="fas fa-weight-hanging me-2 text-primary"></i>Estoque Inicial (kg):
                                </label>
                                <div class="input-group">
                                    <input type="number" step="0.01" name="estoque" id="estoque" class="form-control" required min="0" placeholder="0.00" />
                                    <span class="input-group-text">kg</span>
                                </div>
                                <small class="text-muted d-block mt-2">
                                    <i class="fas fa-chart-line me-1"></i>
                                    Redução por hora: 10% do estoque
                                </small>
                            </div>
                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-chart-line me-2"></i> Calcular Dinâmico
                                </button>
                                <button type="button" class="btn btn-secondary" onclick="document.getElementById('estoque').value=''; document.getElementById('estoque').focus();">
                                    <i class="fas fa-redo me-2"></i> Limpar
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="history-table card mt-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fas fa-history me-2"></i> Histórico de Cálculos</span>
                <span class="badge bg-light text-dark">@(Model?.Count ?? 0) registros</span>
            </div>
            <div class="card-body p-0">
                @if (Model != null && Model.Count > 0)
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Tipo</th>
                                    <th>Entrada</th>
                                    <th>Resultado</th>
                                    <th>Data/Hora</th>
                                    <th class="text-center">Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var calculo in Model)
                                {
                                    <tr>
                                        <td>
                                            <span class="status-badge @calculo.Tipo.ToLower().Replace("á", "a")">
                                                @(calculo.Tipo == "estático" ? "Estático" : "Dinâmico")
                                            </span>
                                        </td>
                                        <td>
                                            <strong>@calculo.Entrada.ToString("F2")</strong>
                                            <span class="text-muted small">
                                                @(calculo.Tipo == "estático" ? "MJ" : "kg")
                                            </span>
                                        </td>
                                        <td>
                                            <strong class="text-primary">@calculo.Resultado.ToString("F2")</strong>
                                            <span class="text-muted small">
                                                @(calculo.Tipo == "estático" ? "Msej" : "kg")
                                            </span>
                                        </td>
                                        <td>
                                            <i class="far fa-calendar-alt me-1 text-muted"></i>
                                            <small>@calculo.Timestamp.ToString("dd/MM/yyyy HH:mm:ss")</small>
                                        </td>
                                        <td class="text-center">
                                            <form asp-action="Deletar" method="post" style="display: inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@calculo.Id" />
                                                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Tem certeza que deseja deletar este cálculo?');">
                                                    <i class="fas fa-trash me-1"></i> Deletar
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <i class="fas fa-inbox fa-4x mb-3" style="color: #ccc;"></i>
                        <p class="h5">Nenhum cálculo registrado ainda.</p>
                        <p class="text-muted">Realize um cálculo acima para começar!</p>
                    </div>
                }
            </div>
        </div>

        <div class="about-section">
            <h2><i class="fas fa-info-circle me-2"></i> Sobre o Projeto</h2>
            <p>
                Este é o <strong>Sistema Emergético</strong>, desenvolvido como parte da APS (Atividades Práticas Supervisionadas) de Engenharia de Software
                O sistema permite calcular a <strong>emergia estática e dinâmica</strong> de sistemas, ajudando a analisar o impacto ambiental e a sustentabilidade de processos.
            </p>

            <div class="row mt-4">
                <div class="col-md-6">
                    <h5><i class="fas fa-cogs text-primary me-2"></i> Como Funciona?</h5>
                    <ul class="list-unstyled">
                        <li class="mb-3">
                            <strong>Cálculo Estático:</strong>
                            <p class="text-muted mt-1">
                                Converte energia em MJ (megajoules) para Msej (megasej) usando o fator de transformação:
                                <code>1 MJ = 1.96E+04 Msej</code>. Um alerta é exibido se o resultado ultrapassar <code>3.56E+07 Msej</code>.
                            </p>
                        </li>
                        <li class="mb-3">
                            <strong>Cálculo Dinâmico:</strong>
                            <p class="text-muted mt-1">
                                Simula a redução de estoque ao longo do tempo, com uma taxa de 10% por hora,
                                ajudando a prever a durabilidade do recurso disponível.
                            </p>
                        </li>
                    </ul>
                </div>
                <div class="col-md-6">
                    <h5><i class="fas fa-keyboard text-primary me-2"></i> Como Usar?</h5>
                    <ol class="list-group list-group-numbered">
                        <li class="list-group-item border-0">Insira um valor em MJ para conversão estática</li>
                        <li class="list-group-item border-0">Ou insira um estoque inicial para cálculo dinâmico</li>
                        <li class="list-group-item border-0">Clique em "Calcular" para processar e salvar</li>
                        <li class="list-group-item border-0">Consulte o histórico para ver registros anteriores</li>
                        <li class="list-group-item border-0">Use o botão "Deletar" para remover registros</li>
                    </ol>
                </div>
            </div>

            <h5 class="mt-4"><i class="fas fa-wrench text-primary me-2"></i> Tecnologias Utilizadas</h5>
            <div class="row mt-3">
                <div class="col-md-6">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item border-0"><i class="fas fa-check-circle text-success me-2"></i>ASP.NET Core 6.0 (MVC)</li>
                        <li class="list-group-item border-0"><i class="fas fa-check-circle text-success me-2"></i>C# 10.0</li>
                        <li class="list-group-item border-0"><i class="fas fa-check-circle text-success me-2"></i>Entity Framework Core 8.0</li>
                    </ul>
                </div>
                <div class="col-md-6">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item border-0"><i class="fas fa-check-circle text-success me-2"></i>MySQL 8.0</li>
                        <li class="list-group-item border-0"><i class="fas fa-check-circle text-success me-2"></i>Bootstrap 5.3</li>
                        <li class="list-group-item border-0"><i class="fas fa-check-circle text-success me-2"></i>Font Awesome 6.5.2</li>
                    </ul>
                </div>
            </div>

            <div class="alert alert-info mt-4 mb-0">
                <i class="fas fa-lightbulb me-2"></i>
                <strong>Nota:</strong> Todos os cálculos são persistidos em banco de dados MySQL e estão disponíveis para análise futura.
                O sistema implementa boas práticas de segurança com anti-forgery tokens e validação de dados.
            </div>
        </div>
    </div>

    <!-- FOOTER REMOVIDO - Será renderizado pelo _Layout.cshtml -->

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
        // Auto-hide alerts after 6 seconds
        const alerts = document.querySelectorAll('.alert');
        alerts.forEach(alert => {
        setTimeout(() => {
        const bsAlert = new bootstrap.Alert(alert);
        bsAlert.close();
        }, 6000);
        });

        // Format numbers in table
        const numberCells = document.querySelectorAll('.table tbody td:nth-child(2), .table tbody td:nth-child(3)');
        numberCells.forEach(cell => {
        const text = cell.textContent.trim().split(' ')[0];
        if (!isNaN(parseFloat(text))) {
        const num = parseFloat(text);
        if (num > 1000) {
        cell.innerHTML = `<strong>${num.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</strong>`;
        }
        }
        });

        // Add loading state to forms
        const forms = document.querySelectorAll('form');
        forms.forEach(form => {
        form.addEventListener('submit', function(e) {
        const submitBtn = this.querySelector('button[type="submit"]');
        if (submitBtn && !submitBtn.disabled) {
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i> Processando...';
        }
        });
        });
        });
    </script>
</body>
</html>